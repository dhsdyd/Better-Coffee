/* 主题色变量 */
page {
  --color-primary: #6F4E37;
  --color-primary-light: #A0826D;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-text: #333333;
  --color-text-light: #999999;
  --color-border: #EEEEEE;
  --color-success: #4CAF50;
  --color-warning: #FF9800;
  --color-danger: #F44336;
  --color-star: #FFB800;

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 主按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary[disabled] {
  background: var(--color-primary-light);
  color: rgba(255, 255, 255, 0.7);
}

/* 次按钮 */
.btn-secondary {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 48rpx;
  padding: 18rpx 38rpx;
  font-size: 30rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-light);
}

.empty-state .empty-text {
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: var(--color-bg);
  color: var(--color-text-light);
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background: rgba(111, 78, 55, 0.1);
  color: var(--color-primary);
}

.tag-success {
  background: rgba(76, 175, 80, 0.1);
  color: var(--color-success);
}

.tag-warning {
  background: rgba(255, 152, 0, 0.1);
  color: var(--color-warning);
}

.tag-danger {
  background: rgba(244, 67, 54, 0.1);
  color: var(--color-danger);
}

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.list-item:last-child {
  border-bottom: none;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-light);
  margin-bottom: 12rpx;
}

.form-input,
.form-picker {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 200rpx;
  box-sizing: border-box;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-light);
}
