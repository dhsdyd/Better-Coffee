<view class="container">
  <view class="section-title">冲煮历史</view>
  <view wx:if="{{list.length === 0}}" class="empty-state">
    <view class="empty-text">还没有冲煮记录</view>
  </view>
  <view class="card brewing-item" wx:for="{{list}}" wx:key="_id" data-id="{{item._id}}" bindtap="handleTap">
    <view class="brewing-header">
      <view class="brewing-name">{{item.beanName}}</view>
      <view class="brewing-time">{{item.timeText}}</view>
    </view>
    <view class="brewing-method">
      <text>{{item.methodLabel}}</text>
      <text class="fav-badge" wx:if="{{item.isFavorite}}">★ 最爱</text>
    </view>
    <view class="brewing-params">{{item.paramsText}}</view>
    <view class="brewing-tags" wx:if="{{item.tasteTags.length > 0}}">
      <text class="tag tag-primary" wx:for="{{item.tasteTags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
    </view>
    <view class="brewing-rating" wx:if="{{item.rating > 0}}">评分：{{item.rating}} 星</view>
  </view>

  <view class="modal-mask" wx:if="{{detail}}" bindtap="handleCloseDetail">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{detail.beanName}}</text>
        <text class="modal-close" bindtap="handleCloseDetail">×</text>
      </view>
      <view class="modal-body">
        <view class="detail-row"><text class="detail-label">时间</text><text>{{detail.timeText}}</text></view>
        <view class="detail-row"><text class="detail-label">方式</text><text>{{detail.methodLabel}}</text></view>
        <view class="detail-row" wx:if="{{detail.params.beanWeight}}"><text class="detail-label">粉量</text><text>{{detail.params.beanWeight}}g</text></view>
        <view class="detail-row" wx:if="{{detail.params.waterWeight}}"><text class="detail-label">水量</text><text>{{detail.params.waterWeight}}g</text></view>
        <view class="detail-row" wx:if="{{detail.params.yieldWeight}}"><text class="detail-label">液重</text><text>{{detail.params.yieldWeight}}g</text></view>
        <view class="detail-row" wx:if="{{detail.params.ratio}}"><text class="detail-label">比例</text><text>1:{{detail.params.ratio}}</text></view>
        <view class="detail-row" wx:if="{{detail.params.grindSize}}"><text class="detail-label">研磨度</text><text>{{detail.params.grindSize}}</text></view>
        <view class="detail-row" wx:if="{{detail.params.waterTemp}}"><text class="detail-label">水温</text><text>{{detail.params.waterTemp}}℃</text></view>
        <view class="detail-row" wx:if="{{detail.params.totalTime}}"><text class="detail-label">时间</text><text>{{detail.params.totalTime}}秒</text></view>
        <view class="detail-row" wx:if="{{detail.params.brewer}}"><text class="detail-label">器具</text><text>{{detail.params.brewer}}</text></view>
        <view class="detail-row" wx:if="{{detail.params.machine}}"><text class="detail-label">咖啡机</text><text>{{detail.params.machine}}</text></view>
        <view class="detail-row"><text class="detail-label">评分</text><text>{{detail.rating}} 星</text></view>
        <view class="detail-row" wx:if="{{detail.tasteTags.length > 0}}">
          <text class="detail-label">风味</text>
          <view class="tag-wrap">
            <text class="tag tag-primary" wx:for="{{detail.tasteTags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>
        <view class="detail-row" wx:if="{{detail.notes}}"><text class="detail-label">备注</text><text>{{detail.notes}}</text></view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" wx:if="{{!detail.isFavorite}}" bindtap="handleMarkFavorite">标记最爱</button>
        <button class="btn-primary" bindtap="handleReuse">复用参数</button>
      </view>
    </view>
  </view>
</view>
