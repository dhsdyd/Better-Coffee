.container { padding: 24rpx; }
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #6F4E37;
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
}
.empty-text { font-size: 28rpx; }
.card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.brewing-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.brewing-name {
  font-size: 30rpx;
  font-weight: 600;
}
.brewing-time {
  font-size: 24rpx;
  color: #999;
}
.brewing-method {
  font-size: 24rpx;
  color: #6F4E37;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}
.fav-badge {
  margin-left: 16rpx;
  color: #FFB800;
  font-size: 22rpx;
}
.brewing-params {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.brewing-tags {
  display: flex;
  flex-wrap: wrap;
}
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}
.tag-primary {
  background: rgba(111,78,55,0.1);
  color: #6F4E37;
}
.brewing-rating {
  font-size: 24rpx;
  color: #FFB800;
}
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  background: #FFF;
  border-radius: 16rpx;
  width: 90%;
  max-height: 85vh;
  overflow-y: auto;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
}
.modal-title { font-size: 32rpx; font-weight: 600; }
.modal-close { font-size: 40rpx; color: #999; padding: 0 12rpx; }
.modal-body { padding: 24rpx; }
.detail-row {
  display: flex;
  padding: 12rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  align-items: flex-start;
}
.detail-label {
  width: 120rpx;
  color: #999;
  flex-shrink: 0;
}
.tag-wrap {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
}
.modal-footer {
  display: flex;
  padding: 24rpx;
  border-top: 1rpx solid #EEEEEE;
  gap: 24rpx;
}
.modal-footer button { flex: 1; margin: 0; }
.btn-primary {
  background: #6F4E37;
  color: #FFF;
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
}
.btn-secondary {
  background: transparent;
  color: #6F4E37;
  border: 2rpx solid #6F4E37;
  border-radius: 48rpx;
  padding: 18rpx 38rpx;
  font-size: 30rpx;
}
