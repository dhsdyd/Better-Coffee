<view class="container">
  <view class="card">
    <view class="form-group">
      <text class="form-label">选择豆子 *</text>
      <picker mode="selector" range="{{beanLabels}}" value="{{beanIndex}}" bindchange="handleBeanChange">
        <view class="form-picker">{{beanLabels[beanIndex] || '请选择'}}</view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">冲煮方式 *</text>
      <picker mode="selector" range="{{methodLabels}}" value="{{methodIndex}}" bindchange="handleMethodChange">
        <view class="form-picker">{{methodLabels[methodIndex]}}</view>
      </picker>
    </view>
  </view>

  <view class="card">
    <view class="section-title-small">冲煮参数</view>
    <brewing-form method="{{method}}" params="{{params}}" bind:change="handleParamsChange"></brewing-form>
  </view>

  <view class="card">
    <view class="section-title-small">评分</view>
    <star-rating value="{{rating}}" bind:change="handleRatingChange"></star-rating>
    <view class="form-group" style="margin-top: 24rpx;">
      <text class="form-label">风味标签</text>
      <view class="tag-list">
        <view 
          class="tag-item {{selectedTags.indexOf(item.value) >= 0 ? 'selected' : ''}}"
          wx:for="{{tasteTags}}" wx:key="value"
          data-value="{{item.value}}"
          bindtap="handleTagTap"
        >{{item.label}}</view>
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">改进方向</text>
      <picker mode="selector" range="{{improvementLabels}}" value="{{improvementIndex}}" bindchange="handleImprovementChange">
        <view class="form-picker">{{improvementLabels[improvementIndex] || '不指定'}}</view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="今天的咖啡感受..." value="{{notes}}" bindinput="handleNotesInput"></textarea>
    </view>
  </view>

  <view class="card" wx:if="{{aiRecommendation}}">
    <view class="section-title-small">AI 推荐分析</view>
    <view class="ai-summary">{{aiRecommendation.summary}}</view>
    <view class="ai-changes" wx:if="{{aiRecommendation.changes}}">建议调整：{{aiRecommendation.changes}}</view>
    <button class="btn-secondary" bindtap="applyAiParams" style="margin-top: 16rpx;">应用推荐参数</button>
  </view>

  <view class="action-bar">
    <button class="btn-secondary" bindtap="handleAiRecommend" loading="{{aiLoading}}">AI 推荐</button>
    <button class="btn-primary" bindtap="handleSave" loading="{{saving}}">保存</button>
  </view>
</view>
