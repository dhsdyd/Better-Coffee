.container { padding: 24rpx; padding-bottom: 200rpx; }
.card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title-small {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.form-picker {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  box-sizing: border-box;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
}
.tag-item {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}
.tag-item.selected {
  background: rgba(111,78,55,0.1);
  color: #6F4E37;
  font-weight: 500;
}
.ai-summary {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 12rpx;
}
.ai-changes {
  font-size: 26rpx;
  color: #6F4E37;
}
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 24rpx;
  background: #FFF;
  gap: 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.action-bar button {
  flex: 1;
  margin: 0;
}
.btn-primary {
  background: #6F4E37;
  color: #FFF;
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
}
.btn-secondary {
  background: transparent;
  color: #6F4E37;
  border: 2rpx solid #6F4E37;
  border-radius: 48rpx;
  padding: 18rpx 38rpx;
  font-size: 30rpx;
}
