.container { padding: 24rpx; }
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #6F4E37;
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.btn-primary {
  background: #6F4E37;
  color: #FFF;
  border-radius: 48rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  line-height: 1;
}
.add-btn {
  margin: 0;
}
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
}
.empty-text {
  font-size: 30rpx;
  margin-bottom: 12rpx;
}
.empty-tip {
  font-size: 24rpx;
  color: #BBB;
}
