<view class="container">
  <view class="header">
    <view class="section-title">我的豆子</view>
    <button class="btn-primary add-btn" bindtap="handleAdd">+ 添加</button>
  </view>
  <view wx:if="{{beans.length === 0}}" class="empty-state">
    <view class="empty-text">还没有添加豆子</view>
    <view class="empty-tip">点击右上角添加按钮</view>
  </view>
  <block wx:for="{{beans}}" wx:key="_id">
    <view bindlongpress="handleLongPress" bindtap="handleTap" data-id="{{item._id}}">
      <bean-card bean="{{item}}"></bean-card>
    </view>
  </block>
  <bean-form visible="{{formVisible}}" bean="{{editingBean}}" bind:close="handleFormClose" bind:save="handleFormSave"></bean-form>
</view>
