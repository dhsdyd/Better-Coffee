<view class="container">
  <view class="card">
    <view class="section-title-small">AI 配置</view>
    <view class="form-group">
      <text class="form-label">服务商</text>
      <picker mode="selector" range="{{providerLabels}}" value="{{providerIndex}}" bindchange="handleProviderChange">
        <view class="form-picker">{{providerLabels[providerIndex]}}</view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">模型</text>
      <input class="form-input" placeholder="如：deepseek-chat" value="{{form.model}}" bindinput="handleModelInput"/>
    </view>
    <view class="form-group">
      <text class="form-label">API Key</text>
      <input class="form-input" placeholder="sk-..." value="{{form.apiKey}}" password="{{!showKey}}" bindinput="handleKeyInput"/>
      <view class="toggle-show" bindtap="toggleShowKey">{{showKey ? '隐藏' : '显示'}}</view>
    </view>
    <view class="saved-info" wx:if="{{savedMaskedKey}}">
      <text>已保存：{{savedMaskedKey}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{testResult}}">
    <view class="section-title-small">连接测试</view>
    <view class="test-result {{testResult.success ? 'success' : 'fail'}}">
      {{testResult.message}}
    </view>
  </view>

  <view class="action-bar">
    <button class="btn-secondary" bindtap="handleTest" loading="{{testing}}">测试连接</button>
    <button class="btn-primary" bindtap="handleSave" loading="{{saving}}">保存</button>
  </view>
</view>
