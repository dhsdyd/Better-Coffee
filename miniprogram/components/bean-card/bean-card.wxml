<view class="bean-card">
  <view class="bean-header">
    <view class="bean-name">{{bean.name}}</view>
    <view class="bean-status-tag status-{{statusInfo.status}}" wx:if="{{statusInfo.status}}">{{statusInfo.label}}</view>
  </view>
  <view class="bean-info">
    <view class="info-row">
      <text class="info-label">产地</text>
      <text class="info-value">{{originLabel}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">品种</text>
      <text class="info-value">{{varietyLabel}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">烘焙度</text>
      <text class="info-value">{{roastLabel}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">烘焙日</text>
      <text class="info-value">{{bean.roastDate}}</text>
    </view>
    <view class="info-row" wx:if="{{bean.process}}">
      <text class="info-label">处理法</text>
      <text class="info-value">{{processLabel}}</text>
    </view>
  </view>
  <view class="bean-weight">
    <view class="weight-text">剩余 {{bean.remainingWeight || 0}}g / {{bean.weight}}g</view>
    <view class="weight-bar">
      <view class="weight-bar-fill" style="width: {{percent}}%;"></view>
    </view>
  </view>
  <view class="finished-badge" wx:if="{{bean.finished}}">已喝完</view>
</view>
