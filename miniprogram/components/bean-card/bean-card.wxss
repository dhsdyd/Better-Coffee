.bean-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.bean-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.bean-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bean-status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.status-resting {
  background: rgba(255,152,0,0.1);
  color: #FF9800;
}
.status-peak {
  background: rgba(76,175,80,0.1);
  color: #4CAF50;
}
.status-late {
  background: rgba(244,67,54,0.1);
  color: #F44336;
}
.status-unknown {
  background: #F5F5F5;
  color: #999;
}
.bean-info {
  margin-bottom: 16rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
}
.info-label {
  color: #999;
}
.info-value {
  color: #333;
}
.bean-weight {
  margin-top: 16rpx;
}
.weight-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.weight-bar {
  width: 100%;
  height: 12rpx;
  background: #EEEEEE;
  border-radius: 6rpx;
  overflow: hidden;
}
.weight-bar-fill {
  height: 100%;
  background: #6F4E37;
  border-radius: 6rpx;
  transition: width 0.3s;
}
.finished-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: #999;
  color: #FFF;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-top-right-radius: 16rpx;
  border-bottom-left-radius: 16rpx;
}
