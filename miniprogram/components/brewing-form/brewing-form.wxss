.brewing-form {
  width: 100%;
}
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx;
}
